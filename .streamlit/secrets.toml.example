# ──────────────────────────────────────────────────────────────
# Copie para .streamlit/secrets.toml e preencha os valores.
# NUNCA faça commit do secrets.toml — está no .gitignore.
#
# No Streamlit Community Cloud, vá em:
# App Settings → Secrets e cole cada linha abaixo.
# ──────────────────────────────────────────────────────────────

# Supabase (banco de dados)
SUPABASE_URL = "https://SEU-PROJETO.supabase.co"
SUPABASE_KEY = "eyJ..."   # anon/public key

# Cloudinary (hospedagem de imagens)
CLOUDINARY_CLOUD   = "seu-cloud-name"
CLOUDINARY_API_KEY = "123456789"
CLOUDINARY_SECRET  = "abc-secret"

# Anthropic (classificação com IA)
ANTHROPIC_API_KEY = "sk-ant-..."
